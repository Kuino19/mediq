# Environment Variables — mediq (KinetiQ)
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Authentication
# ─────────────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — AI / Groq API
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Database (libSQL / Turso)
# ─────────────────────────────────────────────────────────────────────────────
# For local SQLite development:
DATABASE_URL=file:./local.db
# For Turso cloud production:
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=REPLACE_WITH_YOUR_TURSO_AUTH_TOKEN

# ─────────────────────────────────────────────────────────────────────────────
# Firebase (optional — push notifications / analytics)
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
